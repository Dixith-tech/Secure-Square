# ============================================
# AI Security Platform — Environment Variables
# ============================================
# Copy this to backend/.env for local development
# Set these in Vercel Dashboard for production

# Database
# LOCAL: SQLite (no setup needed)
DATABASE_URL=sqlite:///./security_platform.db
# PRODUCTION: Supabase PostgreSQL (set in Vercel dashboard)
# DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Security — generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sb_publishable_qSqc8j1BFtxVoiGbIK1-DA_y_V4qalW

# CORS Origins (comma-separated)
# LOCAL:
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
# PRODUCTION (set in Vercel dashboard):
# CORS_ORIGINS=https://your-app.vercel.app

# Email Alerts (optional)
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=465
