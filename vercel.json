{
  "experimentalServices": {
    "frontend": {
      "type": "web",
      "src": "frontend",
      "framework": "nextjs",
      "installCommand": "npm install",
      "buildCommand": "npm run build",
      "outputDirectory": ".next"
    },
    "backend": {
      "type": "web",
      "src": "backend",
      "framework": "fastapi",
      "installCommand": "pip install -r requirements.txt",
      "buildCommand": "",
      "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port $PORT"
    }
  }
}
